<%- include('../partials/header') %>

<main>
    <h1>Faculty List</h1>
    <p>Here's a list of the faculty members.</p>

    <div class="faculty-sorting">
        <span>Sort by: </span>

        <a href="/faculty?sort=name"
           class="<%= currentSort === 'name' ? 'active' : '' %>">
           Name
        </a>

        <a href="/faculty?sort=department"
           class="<%= currentSort === 'department' ? 'active' : '' %>">
           Department
        </a>

        <a href="/faculty?sort=title"
           class="<%= currentSort === 'title' ? 'active' : '' %>">
           Title
        </a>
    </div>

    <div class="faculty-list">

        <% faculty.forEach(faculty => { %>

            <li class="faculty-card">

                <img src="/images/faculty/<%= faculty.slug %>.jpg" alt="<%= faculty.name %>" class="faculty-photo">
                <h3>
                    <a href="/faculty/<%= faculty.slug %>">
                        <%= faculty.name %>
                    </a>
                </h3>

                <p class="faculty-title">
                    <%= faculty.title %>
                </p>

                <p class="faculty-department">
                    <%= faculty.department %>
                </p>

            </li>

        <% }); %>

    </div>
</main>

<%- include('../partials/footer') %>